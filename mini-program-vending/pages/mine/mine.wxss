/* 我的页样式 */
.container {
  padding: 16rpx;
  background: #0f172a;
  min-height: 100vh;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  background: #1e293b;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
}

.avatar {
  font-size: 72rpx;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  color: #f1f5f9;
  font-size: 34rpx;
  font-weight: bold;
  display: block;
}

.user-id {
  color: #64748b;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.role-badge {
  background: rgba(59, 130, 246, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
}

.role-badge text {
  color: #60a5fa;
  font-size: 24rpx;
}

.role-badge.admin {
  background: rgba(245, 158, 11, 0.2);
}

.role-badge.admin text {
  color: #f59e0b;
}

/* 菜单 */
.menu-section {
  margin-bottom: 24rpx;
}

.menu-title {
  color: #64748b;
  font-size: 24rpx;
  padding: 0 0 12rpx 8rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  background: #1e293b;
  padding: 28rpx 24rpx;
  margin-bottom: 2rpx;
}

.menu-item:first-of-type {
  border-radius: 16rpx 16rpx 0 0;
}

.menu-item:last-of-type {
  border-radius: 0 0 16rpx 16rpx;
  margin-bottom: 0;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  color: #f1f5f9;
  font-size: 28rpx;
  flex: 1;
}

.menu-desc {
  color: #64748b;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.menu-arrow {
  color: #475569;
  font-size: 34rpx;
}

.server-input {
  color: #60a5fa;
  font-size: 24rpx;
  text-align: right;
  width: 300rpx;
}

/* 登录弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-box {
  background: #1e293b;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 560rpx;
}

.modal-title {
  color: #f1f5f9;
  font-size: 34rpx;
  font-weight: bold;
  text-align: center;
  display: block;
  margin-bottom: 32rpx;
}

.modal-input {
  background: #0f172a;
  color: #f1f5f9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 32rpx;
  font-size: 28rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
}

.btn-cancel {
  background: #334155;
  color: #94a3b8;
}

.btn-confirm {
  background: #3b82f6;
  color: white;
}
