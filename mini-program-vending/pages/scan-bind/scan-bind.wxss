/* 扫码绑定页 */
.container {
  padding: 48rpx 32rpx;
  background: #0f172a;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bind-card {
  background: #1e293b;
  border-radius: 24rpx;
  padding: 60rpx 48rpx;
  text-align: center;
  width: 100%;
  box-sizing: border-box;
  margin-bottom: 40rpx;
}

.bind-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 24rpx;
}

.bind-title {
  color: #f1f5f9;
  font-size: 34rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.bind-desc {
  color: #64748b;
  font-size: 26rpx;
  display: block;
  line-height: 1.6;
}

.scan-btn {
  margin-top: 40rpx;
  background: #3b82f6;
  color: white;
  border-radius: 16rpx;
  font-size: 32rpx;
  padding: 24rpx;
}

.bind-status {
  color: #10b981;
  font-size: 28rpx;
  display: block;
  text-align: center;
}

.manual-section {
  width: 100%;
  margin-bottom: 32rpx;
}

.manual-title {
  color: #94a3b8;
  font-size: 26rpx;
  margin-bottom: 16rpx;
  display: block;
}

.url-input-row {
  display: flex;
  gap: 16rpx;
}

.url-input {
  flex: 1;
  background: #1e293b;
  color: #e2e8f0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.save-btn {
  background: #334155;
  color: #e2e8f0;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 32rpx;
}

.home-btn {
  margin-top: 40rpx;
  background: #1e293b;
  color: #94a3b8;
  border: 2rpx solid #334155;
  border-radius: 16rpx;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  width: auto;
}
