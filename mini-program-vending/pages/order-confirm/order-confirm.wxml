<!-- 下单确认页 -->
<view class="container">
  <!-- 商品信息 -->
  <view class="product-section" wx:if="{{product}}">
    <image class="product-img" src="{{product.image}}" mode="aspectFill" />
    <view class="product-info">
      <text class="product-name">{{product.name}}</text>
      <text class="product-price">¥{{product.price}} / 件</text>
    </view>
  </view>

  <!-- 数量选择 -->
  <view class="section">
    <text class="section-title">数量</text>
    <view class="qty-control">
      <view class="qty-btn {{quantity <= 1 ? 'disabled' : ''}}" bindtap="onMinus">
        <text>-</text>
      </view>
      <text class="qty-value">{{quantity}}</text>
      <view class="qty-btn" bindtap="onPlus">
        <text>+</text>
      </view>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="section">
    <text class="section-title">支付方式</text>
    <view class="payment-options">
      <view class="payment-option {{paymentMethod === 'face' ? 'active' : ''}}"
            data-method="face" bindtap="onPaymentChange">
        <text class="payment-icon">😊</text>
        <text class="payment-label">人脸支付</text>
        <text class="payment-check" wx:if="{{paymentMethod === 'face'}}">✓</text>
      </view>
      <view class="payment-option {{paymentMethod === 'scan' ? 'active' : ''}}"
            data-method="scan" bindtap="onPaymentChange">
        <text class="payment-icon">📱</text>
        <text class="payment-label">扫码支付</text>
        <text class="payment-check" wx:if="{{paymentMethod === 'scan'}}">✓</text>
      </view>
    </view>
  </view>

  <!-- 底部结算 -->
  <view class="footer-bar">
    <view class="total-info">
      <text class="total-label">合计</text>
      <text class="total-price">¥{{totalPrice}}</text>
    </view>
    <button class="submit-btn {{submitting ? 'loading' : ''}}"
            bindtap="onSubmit"
            disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交订单'}}
    </button>
  </view>
</view>
