/* 下单确认页样式 */
.container {
  padding: 16rpx;
  background: #0f172a;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.product-section {
  display: flex;
  align-items: center;
  background: #1e293b;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.product-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 14rpx;
  margin-right: 24rpx;
  background: #334155;
}

.product-name {
  color: #f1f5f9;
  font-size: 34rpx;
  font-weight: bold;
  display: block;
}

.product-price {
  color: #f59e0b;
  font-size: 28rpx;
  margin-top: 8rpx;
}

.section {
  background: #1e293b;
  border-radius: 20rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  color: #94a3b8;
  font-size: 26rpx;
  display: block;
  margin-bottom: 20rpx;
}

/* 数量控制 */
.qty-control {
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #334155;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-btn text {
  color: #f1f5f9;
  font-size: 36rpx;
}

.qty-btn.disabled {
  opacity: 0.3;
}

.qty-value {
  color: #f1f5f9;
  font-size: 40rpx;
  font-weight: bold;
  margin: 0 60rpx;
}

/* 支付方式 */
.payment-options {
  display: flex;
  gap: 20rpx;
}

.payment-option {
  flex: 1;
  background: #0f172a;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  border: 2rpx solid transparent;
  position: relative;
}

.payment-option.active {
  border-color: #3b82f6;
  background: rgba(59, 130, 246, 0.1);
}

.payment-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

.payment-label {
  color: #94a3b8;
  font-size: 26rpx;
}

.payment-option.active .payment-label {
  color: #60a5fa;
}

.payment-check {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  color: #3b82f6;
  font-size: 28rpx;
}

/* 底部栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #1e293b;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.total-label {
  color: #94a3b8;
  font-size: 26rpx;
  display: block;
}

.total-price {
  color: #f59e0b;
  font-size: 40rpx;
  font-weight: bold;
}

.submit-btn {
  background: #3b82f6;
  color: white;
  border-radius: 16rpx;
  padding: 20rpx 48rpx;
  font-size: 30rpx;
}

.submit-btn.loading {
  opacity: 0.6;
}
