CONFIG_FATFS_VFS_FSTAT_BLKSIZE=4096

# PSRAM (required for camera frame buffers ~2.4MB)
CONFIG_SPIRAM=y

# WiFi + Web Server (via ESP-Hosted ESP32-C6)
# Note: CONFIG_ESP_WIFI_ENABLED must NOT be set for ESP32-P4 (no native WiFi)
# The esp_wifi_remote component handles WiFi through ESP-Hosted
CONFIG_APP_WIFI_ENABLED=y
CONFIG_APP_WIFI_SSID="myssid"
CONFIG_APP_WIFI_PASSWORD="mypassword"
CONFIG_APP_WIFI_MAX_RETRY=5

# WDT: enable but don't panic, don't check idle tasks (prevents periodic reset)
CONFIG_ESP_TASK_WDT_EN=y
CONFIG_ESP_TASK_WDT_INIT=y
# CONFIG_ESP_TASK_WDT_PANIC is not set
CONFIG_ESP_TASK_WDT_TIMEOUT_S=5
# CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU0 is not set
# CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU1 is not set

# Flash size (face detection models need large flash)
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"

# Custom partition table (4MB app partition for face detection models)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# SPI LCD Touch - XPT2046
CONFIG_SPI_LCD_TOUCH_ENABLED=y
CONFIG_SPI_LCD_TOUCH_CONTROLLER_XPT2046=y

# Enable Montserrat 18/20/28/48 fonts for vending machine UI
CONFIG_LV_FONT_MONTSERRAT_18=y
CONFIG_LV_FONT_MONTSERRAT_20=y
CONFIG_LV_FONT_MONTSERRAT_28=y
CONFIG_LV_FONT_MONTSERRAT_48=y

# Camera OV5647 (800x800 RAW8)
CONFIG_CAMERA_OV5647=y
CONFIG_EXAMPLE_MIPI_CSI_HRES_800=y
CONFIG_EXAMPLE_MIPI_CSI_VRES_800=y

# Face recognition feature model (for face ID matching)
CONFIG_FLASH_HUMAN_FACE_FEAT_MFN_S8_V1=y

# ESP-SR Speech Recognition
CONFIG_SR_VADN_VADNET1_MEDIUM=y
CONFIG_SR_WN_WN9_HILEXIN=y
CONFIG_SR_MN_CN_MULTINET7_QUANT=y

