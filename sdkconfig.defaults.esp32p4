CONFIG_SLAVE_IDF_TARGET_ESP32C6=y
CONFIG_ESP_HOSTED_CP_TARGET_ESP32C6=y
CONFIG_ESP_HOSTED_P4_DEV_BOARD_FUNC_BOARD=y
CONFIG_ESP_HOSTED_SDIO_HOST_INTERFACE=y

# ESP32-P4 has no native WiFi — disable esp_wifi native, use esp_wifi_remote
# CONFIG_ESP_WIFI_ENABLED is not set
CONFIG_ESP_WIFI_REMOTE_ENABLED=y

# Reduce SDIO mempool/queue memory usage
CONFIG_ESP_HOSTED_USE_MEMPOOL=n
CONFIG_ESP_HOSTED_SDIO_TX_Q_SIZE=10
CONFIG_ESP_HOSTED_SDIO_RX_Q_SIZE=10

CONFIG_WIFI_RMT_STATIC_RX_BUFFER_NUM=16
CONFIG_WIFI_RMT_DYNAMIC_RX_BUFFER_NUM=64
CONFIG_WIFI_RMT_DYNAMIC_TX_BUFFER_NUM=64
CONFIG_WIFI_RMT_AMPDU_TX_ENABLED=y
CONFIG_WIFI_RMT_TX_BA_WIN=32
CONFIG_WIFI_RMT_AMPDU_RX_ENABLED=y
CONFIG_WIFI_RMT_RX_BA_WIN=32

# ESP32-P4 revision (for ESP-SR compatibility)
CONFIG_ESP32P4_SELECTS_REV_LESS_V3=y

# Cache configuration (recommended for ESP32-P4)
CONFIG_CACHE_L2_CACHE_256KB=y
CONFIG_CACHE_L2_CACHE_LINE_128B=y

# I2S configuration for audio
CONFIG_I2S_ISR_IRAM_SAFE=y

# I2C - Skip legacy conflict check
CONFIG_I2C_SKIP_LEGACY_CONFLICT_CHECK=y

# Experimental features (required for some ESP32-P4 features)
CONFIG_IDF_EXPERIMENTAL_FEATURES=y
